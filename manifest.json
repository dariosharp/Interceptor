{
  "manifest_version": 3,
  "name": "Interceptor",
  "description": "A lightweight DevTools request history and repeater for authorized web application testing.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "debugger",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "Icons/interceptor-16.png",
    "32": "Icons/interceptor-32.png",
    "48": "Icons/interceptor-48.png",
    "128": "Icons/interceptor-128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Interceptor",
    "default_icon": {
      "16": "Icons/interceptor-16.png",
      "32": "Icons/interceptor-32.png",
      "48": "Icons/interceptor-48.png",
      "128": "Icons/interceptor-128.png"
    }
  }
}
